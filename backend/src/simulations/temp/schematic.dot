digraph "and_gate" {
label="and_gate";
rankdir="LR";
remincross=true;
n2 [ shape=octagon, label="Y", color="black", fontcolor="black" ];
n3 [ shape=octagon, label="B", color="black", fontcolor="black" ];
n4 [ shape=octagon, label="A", color="black", fontcolor="black" ];
c5 [ shape=record, label="{{<p4> A|<p3> B}|$1\n$and|{<p2> Y}}",  ];
x0 [shape=point, ];
c5:p2:e -> x0:w [color="black", fontcolor="black", label=""];
x0:e -> n2:w [color="black", fontcolor="black", label=""];
n3:e -> c5:p3:w [color="black", fontcolor="black", label=""];
n4:e -> c5:p4:w [color="black", fontcolor="black", label=""];
}
